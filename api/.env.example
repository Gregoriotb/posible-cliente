# === Artificialic Budget Platform — Backend config ===

# Database
#   Local dev (default):   SQLite, archivo local
#   Producción:            Neon Postgres con driver psycopg v3
DATABASE_URL=sqlite:///./artificialic.db
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/artificialic?sslmode=require

# CORS whitelist (separado por comas). En prod, URL final del dashboard en Vercel.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGINS=https://artificialic-dashboard.vercel.app

# Rate limit default por API Key (requests por minuto)
RATE_LIMIT_DEFAULT=60

# Bootstrap: en el primer arranque (DB vacía), crea una admin key y persiste en ADMIN_KEY.txt.
# En prod: true el primer deploy (para obtener la key inicial), luego false.
BOOTSTRAP_ADMIN_ON_EMPTY=true

# Exponer Swagger UI en /docs. En prod, poner false para ocultar endpoints internos.
ENABLE_DOCS=true

# Entorno (afecta logging y manejo de errores)
ENVIRONMENT=development
# ENVIRONMENT=production

# === Login del dashboard (opcional) ===
# Si los 3 están seteados, POST /v1/auth/login acepta user/pass y devuelve
# el plaintext de ADMIN_API_KEY al frontend (que lo guarda en localStorage).
# Si falta alguno, el endpoint devuelve 503 y el dashboard no se puede usar
# con login — quedaría solo el camino de pegar la key (ya retirado del UI).
# ADMIN_USERNAME=gregoriotb
# ADMIN_PASSWORD=cambia-esto-por-algo-robusto
# ADMIN_API_KEY=artf_live_...
